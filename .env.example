# Clau de Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-key-here

# Clau de Pinecone (https://app.pinecone.io)
PINECONE_API_KEY=your-key-here
PINECONE_INDEX_NAME=sigphi-corpus

# Selector de backend: pinecone (actiu) o chroma (futur)
VECTOR_DB_TYPE=pinecone

# Model d'embeddings local
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Mida del batch per a upserts
INGEST_BATCH_SIZE=100
