# Caddy: reverse proxy amb HTTPS automàtic (Let's Encrypt) per a SigPhi.
#
# Domini: sigphiai.com  ->  registre A  ->  46.38.243.234 (el VPS).
# Caddy treu i renova el certificat sol; fa de proxy cap a uvicorn (localhost:8000).
#
# Aplicar:  sudo bash deploy/setup_caddy.sh
# (o manualment: sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy)

sigphiai.com, www.sigphiai.com {
    reverse_proxy 127.0.0.1:8000
}
